DATABASE_URL=postgresql://user:password@localhost:5432/camila

# Superadmin — credenciales del administrador principal (REQUERIDO en producción)
SUPERADMIN_EMAIL=admin@camila.pe
SUPERADMIN_PASSWORD=

# Seed de tiendas demo — solo activar en desarrollo/staging
SEED_DEMO_STORES=false
SEED_DEMO_PASSWORD=

# Resend — transactional emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL base del frontend (sin trailing slash)
FRONTEND_URL=https://camila.pe

# CORS — orígenes permitidos en producción (coma separados)
ALLOWED_ORIGINS=https://camila.pe,https://www.camila.pe

# Culqi — pasarela de pagos (https://culqi.com)
CULQI_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CULQI_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
CULQI_WEBHOOK_SECRET=wh_xxxxxxxxxxxxxxxxxxxx

# Sentry — monitoreo de errores (opcional)
SENTRY_DSN=https://xxxx@sentry.io/xxxx

NODE_ENV=development
